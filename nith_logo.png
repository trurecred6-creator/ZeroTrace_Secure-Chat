<section>
    <div style="margin-bottom: 20px; margin-top: 10px; max-width: 1180px; margin-left: auto; margin-right: auto; padding: 0 15px;">
        <div style="display: flex; flex-wrap: wrap;">

            <div style="flex: 0 0 25%; max-width: 25%; padding: 0 1px; box-sizing: border-box;">
                <div style="text-align: center; border-radius: 5px; background-color: #640f12; padding: 6px 2px; margin: 1px;">
                    <a href="https://nith.ac.in/research-consultancy" style="color: white !important; text-decoration: none; display: block; font-size: 0.9em;">Research & Consultancy</a>
                </div>
